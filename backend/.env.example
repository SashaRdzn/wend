# Скопируйте в .env и задайте значения (файл .env не коммитить)

NODE_ENV=production
PORT=4000
# Для VPS / Docker — слушать все интерфейсы:
# HOST=0.0.0.0

# Обязательно смените на продакшене:
ADMIN_PASSWORD=your-secure-password

# Постоянная БД на хостинге (Render Disk и т.п.), иначе SQLite в контейнере обнуляется:
# SQLITE_PATH=/data/wedding.sqlite
